class _MiniChartPainter extends CustomPainter {
  @override
  void paint(Canvas canvas, Size size) {
    final p = Paint()..color = const Color(0xFF4CAF50)..strokeWidth = 2..style = PaintingStyle.stroke..strokeCap = StrokeCap.round;
    final pts = [
      Offset(0, size.height * .7), Offset(size.width * .2, size.height * .4),
      Offset(size.width * .4, size.height * .6), Offset(size.width * .6, size.height * .2),
      Offset(size.width * .8, size.height * .5), Offset(size.width, size.height * .3),
    ];
    final path = Path()..moveTo(pts[0].dx, pts[0].dy);
    for (int i = 1; i < pts.length; i++) path.lineTo(pts[i].dx, pts[i].dy);
    canvas.drawPath(path, p);
  }
  @override bool shouldRepaint(covariant CustomPainter _) => false;
}

