          ]),
          const Spacer(),
          if (hasChart)
            SizedBox(width: 60, height: 30, child: CustomPaint(painter: _HeartLinePainter())),
          if (hasDots)
            Row(children: List.generate(6, (i) => Container(
              margin: const EdgeInsets.only(right: 2), width: 8, height: 8,
              decoration: BoxDecoration(color: i < 5 ? const Color(0xFF4CAF50) : Colors.grey.shade300, shape: BoxShape.circle),
