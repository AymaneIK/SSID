class _SkeletonPainter extends CustomPainter {
  @override
  void paint(Canvas canvas, Size size) {
    final p = Paint()..color = const Color(0xFFCCE5CC)..strokeWidth = 2.5..style = PaintingStyle.stroke..strokeCap = StrokeCap.round;
    final cx = size.width / 2;
    canvas.drawCircle(Offset(cx, 30), 24, p);
    canvas.drawLine(Offset(cx, 54), Offset(cx, 180), p);
    canvas.drawLine(Offset(cx - 60, 80), Offset(cx + 60, 80), p);
    canvas.drawLine(Offset(cx - 60, 80), Offset(cx - 80, 140), p);
    canvas.drawLine(Offset(cx - 80, 140), Offset(cx - 70, 200), p);
    canvas.drawLine(Offset(cx + 60, 80), Offset(cx + 80, 140), p);
    canvas.drawLine(Offset(cx + 80, 140), Offset(cx + 70, 200), p);
    canvas.drawLine(Offset(cx - 40, 180), Offset(cx + 40, 180), p);
    canvas.drawLine(Offset(cx - 30, 180), Offset(cx - 40, 250), p);
    canvas.drawLine(Offset(cx - 40, 250), Offset(cx - 35, 310), p);
    canvas.drawLine(Offset(cx + 30, 180), Offset(cx + 40, 250), p);
    canvas.drawLine(Offset(cx + 40, 250), Offset(cx + 35, 310), p);
    final ribP = Paint()..color = const Color(0xFFCCE5CC).withOpacity(0.7)..strokeWidth = 1.5..style = PaintingStyle.stroke;
    for (int i = 0; i < 4; i++) {
      canvas.drawArc(Rect.fromCenter(center: Offset(cx, 100.0 + i * 16), width: 80, height: 20), 0, 3.14, false, ribP);
    }
    canvas.drawCircle(Offset(cx - 10, 115), 10, Paint()..color = Colors.red.shade200..style = PaintingStyle.fill);
  }
  @override bool shouldRepaint(covariant CustomPainter _) => false;
}

