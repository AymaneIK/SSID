class _HeartLinePainter extends CustomPainter {
  @override
  void paint(Canvas canvas, Size size) {
    final p = Paint()..color = const Color(0xFF4CAF50)..strokeWidth = 2..style = PaintingStyle.stroke..strokeCap = StrokeCap.round;
    final path = Path()
      ..moveTo(0, size.height * .5)
      ..lineTo(size.width * .2, size.height * .5)
      ..lineTo(size.width * .3, size.height * .1)
      ..lineTo(size.width * .4, size.height * .9)
      ..lineTo(size.width * .5, size.height * .3)
      ..lineTo(size.width * .6, size.height * .5)
      ..lineTo(size.width, size.height * .5);
    canvas.drawPath(path, p);
  }
  @override bool shouldRepaint(covariant CustomPainter _) => false;
}

